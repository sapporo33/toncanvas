<canvas id="c" width="180" height="180"></canvas>
<script>
const ctx = document.getElementById("c").getContext("2d");

// Background gelap
ctx.fillStyle = "#111111";
ctx.fillRect(0, 0, 180, 180);

// Buat pola pixel dengan gradasi warna cyan → magenta
for (let i = 0; i < 10; i++) {
  for (let j = 0; j < 10; j++) {
    // Hitung warna gradasi
    const r = Math.floor((i / 9) * 255);
    const g = 255;
    const b = Math.floor((j / 9) * 255);
    ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;

    // Ukuran pixel sedikit bervariasi untuk efek “dynamic”
    const size = 14 + Math.floor(Math.random() * 3); 
    ctx.fillRect(i * 18 + 2, j * 18 + 2, size, size);
  }
}

// Optional: Tambahkan lingkaran transparan di tengah
ctx.beginPath();
ctx.arc(90, 90, 40, 0, 2 * Math.PI);
ctx.fillStyle = "rgba(0,255,255,0.15)";
ctx.fill();
</script>
